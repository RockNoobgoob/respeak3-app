{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "commonjs",
    "moduleResolution": "node",
    "esModuleInterop":  true,
    "strict":           true,
    "outDir":           "./dist",
    "rootDir":          "./scripts",
    "resolveJsonModule": true,
    "skipLibCheck":     true
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", "generated"]
}
